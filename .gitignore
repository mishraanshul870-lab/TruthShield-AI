# ============================================================
# TruthShield AI — .gitignore
# ============================================================

# ------------------------------------------------------------
# Secrets and environment configuration
# ------------------------------------------------------------
.env
.env.*
!.env.example
.env.backup
.env*.local

# ------------------------------------------------------------
# Node.js dependencies
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
dist/
dist-ssr/
build/

# ------------------------------------------------------------
# Uploaded user files (keep folder via .gitkeep)
# ------------------------------------------------------------
backend/uploads/*
!backend/uploads/.gitkeep

# ------------------------------------------------------------
# Logs and diagnostics
# ------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------
# Test coverage
# ------------------------------------------------------------
coverage/

# ------------------------------------------------------------
# Editor and OS artifacts
# ------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.sw?
*.ntvs*
*.njsproj
*.sln

# ------------------------------------------------------------
# Vite and build tooling caches
# ------------------------------------------------------------
.vite/
.cache/
*.tsbuildinfo

# ------------------------------------------------------------
# Local databases (SQLite, LowDB, etc.)
# ------------------------------------------------------------
*.sqlite
*.db

# ------------------------------------------------------------
# Generated archives
# ------------------------------------------------------------
*.zip
*.tar
*.gz
*.tar.gz

# ------------------------------------------------------------
# Temporary directories
# ------------------------------------------------------------
tmp/
temp/

# ------------------------------------------------------------
# Test / debug output files
# ------------------------------------------------------------
backend/utils/test_output*.pdf

# ------------------------------------------------------------
# AI agent task tracking files (not project documentation)
# ------------------------------------------------------------
task.md
walkthrough.md

# ------------------------------------------------------------
# Package manager lockfiles (optional — remove if you prefer
# to commit them for reproducible installs)
# NOTE: package-lock.json files are intentionally committed.
# ------------------------------------------------------------

backend/database.json